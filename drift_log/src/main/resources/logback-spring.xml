<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
  <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

  <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="drift_log"/>

  <springProfile name="local,default">
    <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
      <http>
        <url>http://localhost:31000/loki/api/v1/push</url>
      </http>
      <format>
        <label>
          <pattern>app=${appName},env=local,level=%level</pattern>
        </label>
        <message>
          <pattern>${FILE_LOG_PATTERN}</pattern>
        </message>
        <sortByTime>true</sortByTime>
      </format>
    </appender>

    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
      <appender-ref ref="LOKI"/>
    </root>
  </springProfile>
</configuration>